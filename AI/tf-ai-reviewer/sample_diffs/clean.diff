diff --git a/infrastructure/storage.tf b/infrastructure/storage.tf
index 2a3b4c5..6d7e8f9 100644
--- a/infrastructure/storage.tf
+++ b/infrastructure/storage.tf
@@ -8,6 +8,14 @@
 resource "google_storage_bucket" "build_artifacts" {
   name                        = "${var.project_id}-build-artifacts"
   location                    = "US"
+  uniform_bucket_level_access = true
+  public_access_prevention    = "enforced"
+
+  versioning {
+    enabled = true
+  }
+
+  lifecycle_rule {
+    condition { age = 90 }
+    action    { type = "Delete" }
+  }
 }
 
+resource "google_storage_bucket_iam_member" "ci_writer" {
+  bucket = google_storage_bucket.build_artifacts.name
+  role   = "roles/storage.objectCreator"
+  member = "serviceAccount:ci-sa@${var.project_id}.iam.gserviceaccount.com"
+}
